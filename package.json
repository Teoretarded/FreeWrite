{
  "name": "freewrite",
  "version": "0.1.0",
  "description": "A free, open-source desktop word processor",
  "license": "GPL-3.0-only",
  "author": "",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "@tiptap/core": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/extension-underline": "^3.26.0",
    "@tiptap/extension-text-style": "^3.26.0",
    "@tiptap/extension-color": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-font-family": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-subscript": "^3.26.0",
    "@tiptap/extension-superscript": "^3.26.0",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/extension-table-row": "^3.26.0",
    "@tiptap/extension-table-cell": "^3.26.0",
    "@tiptap/extension-table-header": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@turbodocx/html-to-docx": "^1.21.0",
    "mammoth": "^1.12.0",
    "turndown": "^7.2.4",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "electron": "^42.3.3",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.freewrite.app",
    "productName": "FreeWrite",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FreeWrite"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
